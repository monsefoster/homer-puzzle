{% extends 'base.html.twig' %}

{% block title %}Proyecto 1 Puzzle{% endblock %}

{% block stylesheets %}
    <style>
        :root {
            --paper: #f6ecd7;
            --paper-shadow: rgba(67, 39, 14, 0.12);
            --ink: #2a1708;
            --accent: #d46a1f;
            --accent-strong: #a94700;
            --accent-soft: #f8be59;
            --panel: rgba(255, 248, 233, 0.86);
            --line: rgba(79, 42, 13, 0.14);
            --success: #235f39;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            color: var(--ink);
            background:
                radial-gradient(circle at top left, rgba(255, 213, 120, 0.9), transparent 33%),
                radial-gradient(circle at bottom right, rgba(188, 71, 5, 0.18), transparent 34%),
                linear-gradient(160deg, #f5d78a 0%, #efb25a 36%, #d76a20 100%);
            font-family: "Avenir Next", "Futura", "Trebuchet MS", sans-serif;
        }

        .page {
            width: min(1120px, calc(100% - 2rem));
            margin: 0 auto;
            padding: 2rem 0 3rem;
        }

        .puzzle-app {
            transition: opacity 180ms ease, transform 180ms ease;
        }

        .puzzle-app.is-updating {
            opacity: 0.58;
            transform: translateY(3px);
            pointer-events: none;
        }

        .puzzle-app.is-fresh .hero,
        .puzzle-app.is-fresh .panel,
        .puzzle-app.is-fresh .card {
            animation: app-refresh 220ms ease;
        }

        @keyframes app-refresh {
            from {
                opacity: 0;
                transform: translateY(8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .hero {
            display: grid;
            gap: 1.5rem;
            padding: 1.8rem;
            border: 1px solid var(--line);
            border-radius: 28px;
            background: var(--panel);
            box-shadow: 0 24px 60px var(--paper-shadow);
            backdrop-filter: blur(10px);
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 0.55rem;
            width: fit-content;
            padding: 0.5rem 0.8rem;
            border-radius: 999px;
            background: rgba(42, 23, 8, 0.08);
            font-size: 0.82rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        h1 {
            margin: 0;
            font-size: clamp(2.4rem, 5vw, 4.7rem);
            line-height: 0.94;
            letter-spacing: -0.05em;
            text-transform: uppercase;
        }

        .hero p {
            margin: 0;
            max-width: 56rem;
            font-size: 1rem;
            line-height: 1.6;
        }

        .summary {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 0.85rem;
        }

        .card {
            padding: 1rem;
            border: 1px solid var(--line);
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.56);
        }

        .card span {
            display: block;
            font-size: 0.78rem;
            letter-spacing: 0.07em;
            text-transform: uppercase;
            opacity: 0.7;
        }

        .card strong {
            display: block;
            margin-top: 0.35rem;
            font-size: 1.65rem;
            line-height: 1.1;
        }

        .layout {
            display: grid;
            grid-template-columns: 300px minmax(0, 1fr);
            gap: 1.25rem;
            margin-top: 1.25rem;
        }

        .panel {
            padding: 1.35rem;
            border: 1px solid var(--line);
            border-radius: 24px;
            background: var(--panel);
            box-shadow: 0 18px 40px var(--paper-shadow);
            backdrop-filter: blur(12px);
        }

        .panel h2 {
            margin: 0 0 0.9rem;
            font-size: 1.1rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .mode-list,
        .actions {
            display: grid;
            gap: 0.8rem;
        }

        .mode-form {
            margin: 0;
        }

        .mode-button,
        .reset-button,
        .dial-button {
            width: 100%;
            border: none;
            cursor: pointer;
        }

        .mode-button {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
            padding: 1rem;
            border-radius: 18px;
            text-align: left;
            color: var(--ink);
            background: rgba(255, 255, 255, 0.72);
            transition: transform 160ms ease, background 160ms ease;
        }

        .mode-button.active {
            background: linear-gradient(135deg, var(--accent-soft), #ffd786);
            box-shadow: inset 0 0 0 2px rgba(42, 23, 8, 0.14);
        }

        .mode-button:hover,
        .dial-button:hover,
        .reset-button:hover {
            transform: translateY(-2px);
        }

        .mode-button strong {
            font-size: 1rem;
        }

        .mode-button span {
            font-size: 0.92rem;
            line-height: 1.5;
            opacity: 0.78;
        }

        .reset-button {
            padding: 0.95rem 1rem;
            border-radius: 16px;
            font: inherit;
            font-weight: 700;
            color: #fff8ef;
            background: linear-gradient(135deg, var(--accent-strong), #7f2e00);
        }

        .dial-grid {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: 0.85rem;
            align-items: stretch;
        }

        .dial-form {
            margin: 0;
        }

        .dial-button {
            display: grid;
            gap: 0.7rem;
            height: 100%;
            padding: 0.95rem 0.75rem 1rem;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.72);
            box-shadow: inset 0 0 0 1px rgba(42, 23, 8, 0.08);
            transition: transform 160ms ease, box-shadow 160ms ease;
        }

        .dial-button:active {
            transform: scale(0.985);
        }

        .dial-button:disabled,
        .mode-button:disabled,
        .reset-button:disabled {
            cursor: wait;
        }

        .dial-button:focus-visible,
        .mode-button:focus-visible,
        .reset-button:focus-visible {
            outline: 3px solid rgba(35, 95, 57, 0.3);
            outline-offset: 3px;
        }

        .dial-button img {
            width: 100%;
            height: auto;
            display: block;
            aspect-ratio: 77 / 111;
            object-fit: contain;
        }

        .dial-meta {
            display: grid;
            gap: 0.15rem;
            text-align: left;
        }

        .dial-meta strong {
            font-size: 0.95rem;
        }

        .dial-meta span {
            font-size: 0.8rem;
            opacity: 0.72;
        }

        .state-code {
            margin: 1.15rem 0 0;
            font-size: 0.92rem;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        .state-code strong {
            font-size: 1rem;
            letter-spacing: 0.14em;
        }

        .status {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            width: fit-content;
            margin-top: 1rem;
            padding: 0.6rem 0.85rem;
            border-radius: 999px;
            background: rgba(35, 95, 57, 0.12);
            color: var(--success);
            font-weight: 700;
        }

        @media (max-width: 980px) {
            .summary,
            .layout,
            .dial-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 720px) {
            .page {
                width: min(100% - 1rem, 100%);
                padding-top: 1rem;
            }

            .summary,
            .layout,
            .dial-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block javascripts %}
    <script src="/puzzle-app.js" defer></script>
{% endblock %}

{% block body %}
    <main class="page">
        <div id="puzzle-app" class="puzzle-app" data-enhanced-puzzle>
            {% include 'puzzle/_app.html.twig' %}
        </div>
    </main>
{% endblock %}
